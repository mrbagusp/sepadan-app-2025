rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ================= HELPERS ================= */
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    /* ===== USERS, PROFILES, PREFERENCES ===== */
    match /users/{userId} { 
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin()); 
    }
    match /profiles/{userId} { 
      allow read: if isSignedIn(); 
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin()); 
    }
    match /preferences/{userId} { 
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin()); 
    }

    /* ===== MATCHES & MESSAGES ===== */
    match /matches/{matchId} {
      allow read, write: if isSignedIn() && (matchId.contains(request.auth.uid) || isAdmin());

      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (matchId.contains(request.auth.uid) || isAdmin());
      }
    }

    /* ===== EXPLORE CONTENT & TIPS PDKT ===== */
    match /daily_devotionals/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /dating_tips/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    
    match /prayer_requests/{id} { 
      allow read: if isSignedIn(); 
      allow create: if isSignedIn(); 
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.submittedBy == request.auth.uid); 
    }
    
    match /events/{id} { 
      allow read: if isSignedIn(); 
      allow create: if isSignedIn(); 
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.submittedBy == request.auth.uid); 
    }
    
    match /testimonials/{id} { 
      allow read: if isSignedIn(); 
      allow create: if isSignedIn(); 
      allow update, delete: if isAdmin(); 
    }

    /* ===== LIKES & PASSES (FIXED FOR MATCHING) ===== */
    match /likes/{userId} { 
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin()); 
      
      match /liked/{targetId} {
        // 🔥 KRUSIAL: Izinkan target (orang yang di-like) membaca data ini untuk memicu proses MATCH
        // User A me-like User B (targetId). User B harus bisa baca ini.
        allow read: if isSignedIn() && (request.auth.uid == userId || request.auth.uid == targetId || isAdmin());
        allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }
    
    match /passes/{userId}/{allPaths=**} { 
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin()); 
    }

    /* ===== SETTINGS (ADMIN) ===== */
    match /settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /* ===== FALLBACK ===== */
    match /{allPaths=**} {
      allow read, write: if isSignedIn() && isAdmin();
    }
  }
}
