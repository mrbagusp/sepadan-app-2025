rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ===================== HELPERS ===================== */
    function isSignedIn() {
      return request.auth != null;
    }

    // Ambil data user dari koleksi 'users'
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Cek apakah user adalah Admin
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserData().get('isAdmin', false) == true;
    }

    // Cek apakah user adalah pemilik dokumen
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Cek status Premium
    function isPremium() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserData().get('isPremium', false) == true;
    }

    /* ===================== USERS ===================== */
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    /* ===================== PROFILES ===================== */
    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    /* ===================== PREFERENCES ===================== */
    match /preferences/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    /* ===================== LIKES & PASSES ===================== */
    match /likes/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      match /likedUsers/{otherUserId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /passes/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      match /passedUsers/{otherUserId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    /* ===================== CONTENT MODERATION ===================== */

    match /daily_devotionals/{devoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    function contentApproved() {
      return resource.data.get('approved', false) == true;
    }

    match /prayer_requests/{id} {
      allow read: if isSignedIn() && (contentApproved() || isOwner(resource.data.get('submittedBy', '')) || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && isOwner(resource.data.get('submittedBy', '')));
    }

    match /events/{id} {
      allow read: if isSignedIn() && (contentApproved() || isOwner(resource.data.get('submittedBy', '')) || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && isOwner(resource.data.get('submittedBy', '')));
    }

    match /testimonials/{id} {
      allow read: if isSignedIn() && (contentApproved() || isOwner(resource.data.get('submittedBy', '')) || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && isOwner(resource.data.get('submittedBy', '')));
    }

    /* ===================== MATCHES & CHATS ===================== */

    match /matches/{matchId} {
      allow read, update: if isSignedIn() && (request.auth.uid in resource.data.get('users', []) || request.auth.uid in resource.data.get('userIds', []) || isAdmin());
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow read, update: if isSignedIn() && (request.auth.uid in resource.data.get('userIds', []) || isAdmin());
      allow create: if isSignedIn();
      
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
      }
    }
  }
}
